PORT=4000
CLIENT_ORIGIN=http://localhost:5175
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/dream-home?retryWrites=true&w=majority
MONGODB_DB_NAME=dream-home
JWT_SECRET=replace_with_a_long_random_secret
TOKEN_TTL=7d

# Optional Cloudinary (recommended for free cloud file storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional OpenAI (enables reasoning plan generation instead of local fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Used only when Cloudinary credentials are not set
UPLOAD_DIR=uploads
